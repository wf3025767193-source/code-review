APP_NAME=AI Code Review Backend
APP_VERSION=0.1.0
APP_DEBUG=false
API_V1_PREFIX=/api/v1
PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=json
REVIEW_API_TOKEN=
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
GITHUB_TOKEN=
GITHUB_API_PROXY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
DEEP_MODEL=deepseek-v4-pro
FAST_MODEL=deepseek-v4-flash
# 数据库 — Docker Compose 部署时请将 localhost 改为 mysql 服务名
# 生产环境务必设置密码，不要使用空密码连接
DATABASE_URL=mysql+aiomysql://root:@localhost:3306/code_review
REDIS_URL=redis://localhost:6379/0
# JWT 密钥必须至少 32 个字符，生产环境请使用随机字符串
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
